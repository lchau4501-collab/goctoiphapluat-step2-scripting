# Environment variables for Góc Tối Pháp Luật Script Generator

# Required: Your Gemini API Key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model to use. Default is gemini-2.5-flash.
# You can also use gemini-2.5-pro for higher quality, but it will be slower and cost more.
GEMINI_MODEL=gemini-2.5-flash
