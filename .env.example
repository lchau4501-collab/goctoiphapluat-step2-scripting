# Configuration for Góc Tối Pháp Luật Script Generator

# ==========================================
# OPTION 1: Simple Config using .env
# ==========================================

# Standard single Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OR multiple Gemini API Keys for rotation (comma-separated, optional)
# GEMINI_API_KEYS=key_1,key_2,key_3

# Optional: Gemini model name. Default is gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Custom OpenAI-compatible endpoints for rotation/backup (optional)
# Format: url|key|model,url|key|model
# CUSTOM_ENDPOINTS=https://openrouter.ai/api/v1|sk-or-key|google/gemini-2.5-flash,http://localhost:11434/v1|ollama-key|llama3


# ==========================================
# OPTION 2: Advanced Config using api_config.json
# ==========================================
# If 'api_config.json' exists in the folder, it takes precedence over the .env settings.
# See api_config.json.example for instructions.
